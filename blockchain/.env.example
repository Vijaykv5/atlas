# Avalanche Fuji RPC endpoint. The public RPC works for basic deploys/tests,
# but a dedicated provider URL is more reliable.
FUJI_RPC_URL=https://api.avax-test.network/ext/bc/C/rpc

# Deployer wallet private key for Hardhat Fuji deployments.
# Use a funded test wallet only. Never use a seed phrase.
DEPLOYER_PRIVATE_KEY=
